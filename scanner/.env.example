# Skill Scanner Environment Variables

# LLM API Key (optional - required for LLM-based analysis)
# If not set, scanner will only run basic static analysis (pattern + static)
SKILL_SCANNER_LLM_API_KEY=

# LLM Model (optional - defaults to scanner's default model)
# Examples: gpt-4, gpt-3.5-turbo, claude-3-opus-20240229
SKILL_SCANNER_LLM_MODEL=
